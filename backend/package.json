{
  "name": "waves-musical-backend",
  "version": "1.0.0",
  "description": "Backend for Waves Musical Project",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm run dev --prefix ../frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "data:import": "node seeder.js",
    "data:destroy": "node seeder.js -d",
    "seed": "node seeder.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "colors": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "puppeteer": "^24.37.5",
    "razorpay": "^2.9.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^1.0.2"
  }
}
